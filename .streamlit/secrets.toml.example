# Copy this file to secrets.toml and fill in real values.
# secrets.toml is in .gitignore — never commit it.

[mongo]
uri = "mongodb+srv://<user>:<password>@<cluster>.mongodb.net/salasar_ahmedabad"
db_name = "salasar_ahmedabad"

# Users: username → bcrypt hash of password
# Generate hash: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt(12)).decode())"
[credentials]
[credentials.admin]
password_hash = "$2b$12$REPLACE_WITH_REAL_HASH"
role = "admin"

[credentials.viewer]
password_hash = "$2b$12$REPLACE_WITH_REAL_HASH"
role = "viewer"
